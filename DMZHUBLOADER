-- UI Builder
--========================
loadSettings() -- 🔄 Load dulu sebelum UI dibangun

for fieldName, _ in pairs(requiredFields) do
    local def = defaultValues[fieldName]
    local savedValue = currentSettings[fieldName]

    if def and typeof(def[1]) == "boolean" then
        local default = savedValue ~= nil and savedValue or def[1]
        currentSettings[fieldName] = default
        MovementTab:AddToggle(fieldName, default, function(value)
            DRMSped(fieldName, value)
        end)
    else
        local default, min, max
        if def then default, min, max = def[1], def[2], def[3] else default, min, max = 1, 0, 100 end
