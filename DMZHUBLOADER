local function toggleRightLeg(state)
    local player = game.Players.LocalPlayer
    local conn = nil

    local function apply(leg)
        if not leg then return end
        leg.Transparency = 1
        return leg:GetPropertyChangedSignal("Transparency"):Connect(function()
            if leg.Transparency < 1 then
                leg.Transparency = 1
            end
        end)
    end

    local function lockLeg(char)
        if conn then
            conn:Disconnect()
            conn = nil
        end

        local rightLeg = char:FindFirstChild("Right Leg")
        if state and rightLeg then
            conn = apply(rightLeg)
        elseif not state and rightLeg then
            rightLeg.Transparency = 0
        end

        char.DescendantAdded:Connect(function(d)
            if d.Name == "Right Leg" and state then
                if conn then conn:Disconnect() end
                conn = apply(d)
            end
        end)
    end

    if player.Character then
        lockLeg(player.Character)
    end

    player.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        lockLeg(char)
    end)
end

