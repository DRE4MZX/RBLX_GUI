-- ── helpers ──────────────────────────────────────────
local TS = TweenService
local function tw(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quint
    dir   = dir   or Enum.EasingDirection.Out
    TS:Create(obj, TweenInfo.new(t, style, dir), props):Play()
end

-- ── reposition stack (tumbuh ke bawah) ───────────────
local function repositionAll()
    for i, data in ipairs(notifications) do
        local targetY = START_Y + ((i - 1) * ((CARD_H + PADDING) / Container.AbsoluteSize.Y))
        tw(data.card, {
            Position = UDim2.new(0.5, -(CARD_W / 2), 0, Container.AbsoluteSize.Y * targetY)
        }, 0.35)
    end
end

-- ── main notify function ──────────────────────────────
function notifydmz(msg, ntype, duration)
    duration = duration or 3

    local cfg = {
        success = { accent = Color3.fromRGB(0, 210, 120),   icon = "✓", label = "SUCCESS" },
        error   = { accent = Color3.fromRGB(235, 75, 75),   icon = "✕", label = "ERROR"   },
        warn    = { accent = Color3.fromRGB(255, 185, 50),  icon = "!", label = "WARNING" },
    }
    local c = cfg[ntype] or { accent = Color3.fromRGB(108, 92, 231), icon = "•", label = "INFO" }

    -- posisi Y awal (off-screen atas) dan target
    local targetYOffset = Container.AbsoluteSize.Y * START_Y
    local offscreenPos  = UDim2.new(0.5, -(CARD_W / 2), 0, -CARD_H - 20)
    local onscreenPos   = UDim2.new(0.5, -(CARD_W / 2), 0, targetYOffset)

    -- ── Card ──
    local card = Instance.new("Frame")
    card.Parent             = Container
    card.Size               = UDim2.new(0, CARD_W, 0, CARD_H)
    card.AnchorPoint        = Vector2.new(0, 0)
    card.Position           = offscreenPos
    card.BackgroundColor3   = Color3.fromRGB(13, 13, 20)
    card.BackgroundTransparency = 1
    card.BorderSizePixel    = 0
    card.ZIndex             = 30
    card.ClipsDescendants   = true

    local cc = Instance.new("UICorner")
    cc.CornerRadius = UDim.new(0, 10)
    cc.Parent = card

    -- border stroke
    local stroke = Instance.new("UIStroke")
    stroke.Color            = c.accent
    stroke.Thickness        = 1
    stroke.Transparency     = 1 -- mulai invisible
    stroke.ApplyStrokeMode  = Enum.ApplyStrokeMode.Border
    stroke.Parent           = card

    -- ── Left accent bar ──
    local accentBar = Instance.new("Frame")
    accentBar.Parent            = card
    accentBar.Size              = UDim2.new(0, 3, 1, -16)
    accentBar.Position          = UDim2.new(0, 0, 0, 8)
    accentBar.BackgroundColor3  = c.accent
    accentBar.BorderSizePixel   = 0
    accentBar.ZIndex            = 31
    Instance.new("UICorner", accentBar).CornerRadius = UDim.new(0, 3)

    -- ── Icon circle ──
    local iconBg = Instance.new("Frame")
    iconBg.Parent               = card
    iconBg.Size                 = UDim2.new(0, 30, 0, 30)
    iconBg.Position             = UDim2.new(0, 11, 0.5, -15)
    iconBg.BackgroundColor3     = c.accent
    iconBg.BackgroundTransparency = 0.78
    iconBg.BorderSizePixel      = 0
    iconBg.ZIndex               = 31
    Instance.new("UICorner", iconBg).CornerRadius = UDim.new(1, 0)

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Parent              = iconBg
    iconLbl.Size                = UDim2.new(1, 0, 1, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text                = c.icon
    iconLbl.Font                = Enum.Font.GothamBold
    iconLbl.TextSize            = 15
    iconLbl.TextColor3          = c.accent
    iconLbl.TextXAlignment      = Enum.TextXAlignment.Center
    iconLbl.TextYAlignment      = Enum.TextYAlignment.Center
    iconLbl.ZIndex              = 32

    -- ── Type label ──
    local typeLbl = Instance.new("TextLabel")
    typeLbl.Parent              = card
    typeLbl.Size                = UDim2.new(1, -56, 0, 17)
    typeLbl.Position            = UDim2.new(0, 50, 0, 9)
    typeLbl.BackgroundTransparency = 1
    typeLbl.Text                = c.label
    typeLbl.Font                = Enum.Font.GothamBold
    typeLbl.TextSize            = 10
    typeLbl.TextColor3          = c.accent
    typeLbl.TextXAlignment      = Enum.TextXAlignment.Left
    typeLbl.ZIndex              = 31

    -- ── Message label ──
    local msgLbl = Instance.new("TextLabel")
    msgLbl.Parent               = card
    msgLbl.Size                 = UDim2.new(1, -56, 0, 22)
    msgLbl.Position             = UDim2.new(0, 50, 0, 26)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Text                 = msg
    msgLbl.Font                 = Enum.Font.Gotham
    msgLbl.TextSize             = 12
    msgLbl.TextColor3           = Color3.fromRGB(205, 202, 228)
    msgLbl.TextXAlignment       = Enum.TextXAlignment.Left
    msgLbl.TextTruncate         = Enum.TextTruncate.AtEnd
    msgLbl.ZIndex               = 31

    -- ── Progress bar track ──
    local progressTrack = Instance.new("Frame")
    progressTrack.Parent            = card
    progressTrack.Size              = UDim2.new(1, -10, 0, 2)
    progressTrack.Position          = UDim2.new(0, 5, 1, -3)
    progressTrack.BackgroundColor3  = Color3.fromRGB(28, 28, 44)
    progressTrack.BorderSizePixel   = 0
    progressTrack.ZIndex            = 31
    Instance.new("UICorner", progressTrack).CornerRadius = UDim.new(0, 2)

    local progressFill = Instance.new("Frame")
    progressFill.Parent             = progressTrack
    progressFill.Size               = UDim2.new(1, 0, 1, 0)
    progressFill.BackgroundColor3   = c.accent
    progressFill.BorderSizePixel    = 0
    progressFill.ZIndex             = 32
    Instance.new("UICorner", progressFill).CornerRadius = UDim.new(0, 2)

    -- ── Register & restack ──
    local data = { card = card }
    table.insert(notifications, 1, data)
    repositionAll()

    -- ── Animate in (slide down from top + fade) ──
    tw(card,   { BackgroundTransparency = 0 }, 0.25)
    tw(stroke, { Transparency = 0.5 },         0.25)
    tw(card,   { Position = onscreenPos },     0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- ── Progress drain ──
    tw(progressFill, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

    -- ── Dismiss ──
    task.delay(duration, function()
        -- slide back up + fade
        tw(card,   { Position = offscreenPos },          0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        tw(card,   { BackgroundTransparency = 1 },       0.28)
        tw(stroke, { Transparency = 1 },                 0.28)
        task.wait(0.32)

        for i, d in ipairs(notifications) do
            if d == data then
                table.remove(notifications, i)
                break
            end
        end
        card:Destroy()
        repositionAll()
    end)
end

