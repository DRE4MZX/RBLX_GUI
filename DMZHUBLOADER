-- Fungsi pasang efek
local function applyEffects(char)
	task.wait(1)
	local head = char:WaitForChild("Head", 5)
	if not head then return end

	-- Copy dari Angry BoboR6
	local npcHead = RS:WaitForChild("NPCs"):WaitForChild("Angry BoboR6").Variants.Default.Head
	local copyList = {"left eye", "right eye", "Handle", "void smoke"}

	for _, name in ipairs(copyList) do
		local obj = npcHead:FindFirstChild(name)
		if obj then
			local clone = obj:Clone()
			clone.Parent = head
		end
	end

	-- Copy ToxicInferno particle
	local sourceAttachment = RS:WaitForChild("Items")
		:WaitForChild("Cosmetics")
		:WaitForChild("ToxicInferno")
		:WaitForChild("CharacterClassic")
		:WaitForChild("Torso")
		:WaitForChild("Attachment")

	for _, obj in ipairs(sourceAttachment:GetChildren()) do
		if obj:IsA("ParticleEmitter") then
			local clone = obj:Clone()
			clone.Parent = head
		end
	end

	-- Samakan warna dengan void smoke
	local sourceEmitter = head:FindFirstChild("void smoke")
	if sourceEmitter and sourceEmitter:IsA("ParticleEmitter") then
		local sourceColor = sourceEmitter.Color
		for _, obj in ipairs(head:GetChildren()) do
			if obj:IsA("ParticleEmitter") and obj ~= sourceEmitter then
				obj.Color = sourceColor
			end
		end
	end

	print("[INFO] Efek berhasil diterapkan ke Head.")
end

