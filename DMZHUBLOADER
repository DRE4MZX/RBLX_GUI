--========================
-- Save / Load
--========================
local function roundNumber(num)
    if typeof(num) ~= "number" then return num end
    -- kalau angka lebih besar dari 100, pakai 2 digit; kalau kecil, pakai 4 digit
    local digits = math.abs(num) >= 100 and 2 or 4
    local mult = 10 ^ digits
    return math.floor(num * mult + 0.5) / mult
end

local function prepareForSave(tbl)
    local cleaned = {}
    for k, v in pairs(tbl) do
        if typeof(v) == "number" then
            cleaned[k] = roundNumber(v)
        else
            cleaned[k] = v
        end
    end
    return cleaned
end

local function saveSettings()
    if writefile then
        local cleaned = prepareForSave(currentSettings)
        local json = HttpService:JSONEncode(cleaned)
        writefile(SettingsFile, json)
    else
        warn("[DRM Debug] ⚠️ writefile tidak tersedia di executor ini.")
    end
end

local function loadSettings()
    if readfile and isfile and isfile(SettingsFile) then
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile(SettingsFile))
        end)
        if ok and type(data) == "table" then
            for k, v in pairs(data) do
                currentSettings[k] = v
            end
        else
            warn("[DRM Debug] ⚠️ Gagal decode settings.")
        end
    else
        print("[DRM Debug] ℹ️ Tidak ada file settings, gunakan default.")
    end
end

--========================
-- Finder & Apply
--========================
local function refreshTableCache()
    cachedTables = {}
    if not getgc then
        warn("[DRM Debug] getgc() is not available in this environment.")
        return
    end
    for _, obj in pairs(getgc(true)) do
        if typeof(obj) == "table" and rawget(obj, "Speed") and typeof(obj.Speed) == "number" then
            table.insert(cachedTables, obj)
        end
    end
end


local function applyToCached(callback)
    for _, tableObj in ipairs(cachedTables) do
        if typeof(tableObj) == "table" then
            local ok, err = pcall(callback, tableObj)
            if not ok then
                warn("[DRM Debug] Gagal apply:", err)
            end
        end
    end
end

local function DRMSped(fieldName, value)
    currentSettings[fieldName] = value
    applyToCached(function(obj)
        if obj and rawget(obj, fieldName) ~= nil then
            local field = obj[fieldName]
            if typeof(field) == "number" then
                obj[fieldName] = value
            elseif typeof(field) == "table" and field.Value then
                field.Value = value
            elseif typeof(field) == "boolean" then
                obj[fieldName] = value
            end
        end
    end)
    saveSettings() -- 🔥 autosave setiap ubah setting
end

