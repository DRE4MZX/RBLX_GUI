-- Fly variables
local FLYING = false
local QEfly = true
local flySpeed = 50
local flyKeyDown, flyKeyUp

-- Ambil HRP
local function getRoot(char)
	return char:FindFirstChild("HumanoidRootPart")
end

-- ✈️ Start Fly
local function startFly()
	local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local humanoid = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid")
	local root = getRoot(char)
	if not root then
		return
	end

	if flyKeyDown then flyKeyDown:Disconnect() end
	if flyKeyUp then flyKeyUp:Disconnect() end

	local CONTROL = { F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0 }
	local speed = 0

	local BG = Instance.new("BodyGyro")
	local BV = Instance.new("BodyVelocity")
	BG.P = 9e4
	BG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	BG.CFrame = root.CFrame
	BG.Parent = root

	BV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	BV.Velocity = Vector3.new(0, 0, 0)
	BV.Parent = root

	humanoid.PlatformStand = true
	FLYING = true

	-- Loop
	task.spawn(function()
		while FLYING do
			task.wait()
			local cam = Camera
			if CONTROL.L + CONTROL.R ~= 0 or CONTROL.F + CONTROL.B ~= 0 or CONTROL.Q + CONTROL.E ~= 0 then
				speed = flySpeed
			else
				speed = 0
			end

			local moveVec = (cam.CFrame.LookVector * (CONTROL.F + CONTROL.B))
				+ ((cam.CFrame * CFrame.new(CONTROL.L + CONTROL.R, (CONTROL.F + CONTROL.B + CONTROL.Q + CONTROL.E) * 0.2, 0)).p - cam.CFrame.p)
			BV.Velocity = moveVec * speed
			BG.CFrame = cam.CFrame
		end

		BV:Destroy()
		BG:Destroy()
		humanoid.PlatformStand = false
	end)

	-- Input
	flyKeyDown = UIS.InputBegan:Connect(function(input, processed)
		if processed then return end
		local val = 1
		if input.KeyCode == Enum.KeyCode.W then
			CONTROL.F = val
		elseif input.KeyCode == Enum.KeyCode.S then
			CONTROL.B = -val
		elseif input.KeyCode == Enum.KeyCode.A then
			CONTROL.L = -val
		elseif input.KeyCode == Enum.KeyCode.D then
			CONTROL.R = val
		elseif input.KeyCode == Enum.KeyCode.E and QEfly then
			CONTROL.Q = val * 2
		elseif input.KeyCode == Enum.KeyCode.Q and QEfly then
			CONTROL.E = -val * 2
		end
	end)

	flyKeyUp = UIS.InputEnded:Connect(function(input)
		if input.KeyCode == Enum.KeyCode.W then
			CONTROL.F = 0
		elseif input.KeyCode == Enum.KeyCode.S then
			CONTROL.B = 0
		elseif input.KeyCode == Enum.KeyCode.A then
			CONTROL.L = 0
		elseif input.KeyCode == Enum.KeyCode.D then
			CONTROL.R = 0
		elseif input.KeyCode == Enum.KeyCode.E then
			CONTROL.Q = 0
		elseif input.KeyCode == Enum.KeyCode.Q then
			CONTROL.E = 0
		end
	end)
end

-- 🧩 Stop Fly
local function stopFly()
	FLYING = false
	if flyKeyDown then flyKeyDown:Disconnect() end
	if flyKeyUp then flyKeyUp:Disconnect() end
	local char = LocalPlayer.Character
	if char then
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		if humanoid then humanoid.PlatformStand = false end
	end
end

