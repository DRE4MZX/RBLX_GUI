-- Fungsi bikin Billboard nama
local function createNameTag(char, isPlayer)
    if not char:FindFirstChild("HumanoidRootPart") then return end
    if char:FindFirstChild("NameTag") then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NameTag"
    billboard.Adornee = char.HumanoidRootPart
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = char

    local text = Instance.new("TextLabel")
    text.Name = "NameLabel"
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = char.Name .. (isPlayer and " [Player]" or " [BOT]")
    text.TextColor3 = isPlayer and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    text.TextStrokeTransparency = 0
    text.TextScaled = false
    text.Font = Enum.Font.SourceSansBold
    text.TextSize = 24 -- default
    text.Parent = billboard
end

-- Fungsi bikin Highlight
local function createHighlight(char, isPlayer)
    if char:FindFirstChild("ESP_Highlight") then return end
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Parent = char
    highlight.Adornee = char
    highlight.FillColor = isPlayer and Color3.fromRGB(0, 255, 255) or Color3.fromRGB(255, 0, 255)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
end

-- Fungsi hapus ESP & nama
local function removeESP(char)
    local highlight = char:FindFirstChild("ESP_Highlight")
    if highlight then highlight:Destroy() end
    local nameTag = char:FindFirstChild("NameTag")
    if nameTag then nameTag:Destroy() end
end

-- Fungsi proses karakter
local function processCharacter(char)
    local isPlayer = Players:FindFirstChild(char.Name) ~= nil
    createHighlight(char, isPlayer)
    createNameTag(char, isPlayer)
end

-- Toggle ESP
local function toggleESP(state)
    ESPEnabled = state

    if ESPEnabled then
        -- Pasang ESP ke semua karakter saat ini
        for _, char in ipairs(gamePlayersFolder:GetChildren()) do
            if char:IsA("Model") then
                processCharacter(char)
            end
        end

        -- Pasang ESP saat ada karakter baru
        gamePlayersFolder.ChildAdded:Connect(function(char)
            if ESPEnabled and char:IsA("Model") then
                char:WaitForChild("HumanoidRootPart", 5)
                processCharacter(char)
            end
        end)

        -- Update ukuran teks tiap frame sesuai jarak
        updateConnection = RunService.RenderStepped:Connect(function()
            for _, char in ipairs(gamePlayersFolder:GetChildren()) do
                local nameTag = char:FindFirstChild("NameTag")
                if nameTag and char:FindFirstChild("HumanoidRootPart") then
                    local label = nameTag:FindFirstChild("NameLabel")
                    if label then
                        local dist = (Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
                        local size = math.clamp(50 / dist * 10, 12, 30)
                        label.TextSize = size
                    end
                end
            end
        end)
    else
        -- Matikan ESP: hapus semua highlight dan nama
        for _, char in ipairs(gamePlayersFolder:GetChildren()) do
            removeESP(char)
        end
        if updateConnection then
            updateConnection:Disconnect()
            updateConnection = nil
        end
    end
end

