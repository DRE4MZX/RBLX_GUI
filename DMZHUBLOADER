    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

    -- MODE SET KEYBIND
    if waitingForKey then
        waitingForKey = false
        keybind = input.KeyCode
        Settings.Keybind = keybind.Name
        SaveSettings()
        notifydmz("Keybind FPS diset ke "..keybind.Name, "success")
        return
    end

    -- 🔥 HARD CHECK enabled
    if not enabled then return end

    -- FPS SWITCH
    if input.KeyCode == keybind then
        fpsToggle = not fpsToggle

        if fpsToggle then
            setfpscap(Settings.EZBCFPS)
            notifydmz("FPS diset ke 40", "success")
        else
            setfpscap(Settings.DefaultFPS)
            notifydmz("FPS kembali ke default", "success")
        end
    end
end)

